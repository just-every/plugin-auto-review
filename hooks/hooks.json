{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/user-prompt-submit.js",
            "timeoutSec": 20,
            "statusMessage": "Capturing Auto Review baseline"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/stop.js",
            "timeoutSec": 300,
            "statusMessage": "Running Auto Review"
          }
        ]
      }
    ]
  }
}
