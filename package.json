{
  "name": "@just-every/plugin-auto-review",
  "version": "0.1.9",
  "description": "Codex Auto Code Review plugin using hooks.",
  "license": "MIT",
  "homepage": "https://github.com/just-every/plugin-auto-review#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/just-every/plugin-auto-review.git"
  },
  "bin": {
    "plugin-auto-review": "scripts/trust-hooks.js"
  },
  "files": [
    ".codex-plugin/**/*",
    "assets/**/*",
    "hooks/**/*",
    "scripts/**/*",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "setup": "node scripts/trust-hooks.js setup",
    "test": "node --test test/*.test.js",
    "trust-hooks": "node scripts/trust-hooks.js trust-hooks"
  },
  "publishConfig": {
    "access": "public"
  }
}
